# ─── Modo local (sem OAuth) ───────────────────────────────────────────────────
# Usado quando GOOGLE_CLIENT_ID não está configurado.
# O app roda sem autenticação e lê arquivos desta pasta local.
CIFRAS_ROOT=C:\Users\SEU_USUARIO\OneDrive\Cifras


# ─── OAuth 2.0 com Google ─────────────────────────────────────────────────────
# Quando configurado, o app exige login com Google e usa o Drive.
#
# Passo a passo no Google Cloud Console:
#   1. Acesse https://console.cloud.google.com
#   2. Crie um projeto (ou use um existente)
#   3. Menu: APIs e Serviços → Biblioteca → ative "Google Drive API"
#   4. Menu: APIs e Serviços → Biblioteca → ative "Google People API"
#   5. Menu: APIs e Serviços → Tela de permissão OAuth
#      - Tipo: Externo  |  Adicione seu e-mail como usuário de teste
#   6. Menu: APIs e Serviços → Credenciais → Criar credencial → ID do cliente OAuth
#      - Tipo: Aplicativo da Web
#      - URI de redirecionamento: http://localhost:5000/oauth/callback
#   7. Copie Client ID e Client Secret abaixo
#
# Para dar acesso a um músico: compartilhe a pasta no Drive com o e-mail dele.

GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# ID da pasta raiz de cifras no Google Drive
# (abra a pasta no Drive → o ID está na URL: drive.google.com/drive/folders/<ID>)
CIFRAS_FOLDER_ID=seu-folder-id


# ─── Google Calendar (opcional) ──────────────────────────────────────────────
# ID do calendário a exibir no widget da home screen.
# Use "primary" para o calendário principal do usuário logado,
# ou o ID de um calendário compartilhado do grupo (ex: abc123@group.calendar.google.com).
# Para encontrar o ID: Google Calendar → ⚙️ Configurações → clique no calendário → "ID do calendário"
# Lembre de ativar a "Google Calendar API" no Google Cloud Console e compartilhar o
# calendário com o e-mail de serviço, se necessário.
GOOGLE_CALENDAR_ID=primary

# Filtro de palavras-chave para o calendário (opcional).
# Apenas eventos cujo título contenha ao menos uma das palavras serão exibidos.
# Separe por vírgula. Deixe em branco para exibir todos os eventos.
# Exemplo: CALENDAR_KEYWORDS=missa,ensaio,louvor,música,repertório,liturgia,celebração,coral
CALENDAR_KEYWORDS=

# ─── Flask ────────────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex())"
FLASK_SECRET_KEY=troque-por-uma-string-aleatoria-longa
